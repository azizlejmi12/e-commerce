@model IEnumerable<EcommerciApp.Models.Commande>

@{
    ViewData["Title"] = "Gestion des Commandes";
}

<div class="container mt-4">
    <h1 class="fw-bold mb-4"><i class="bi bi-list-ul me-2"></i>Liste des Commandes</h1>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <table class="table align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">@Html.DisplayNameFor(model => model.DateCommande)</th>
                    <th>@Html.DisplayNameFor(model => model.Statut)</th>
                    <th>@Html.DisplayNameFor(model => model.Total)</th>
                    @* --- NOUVELLES COLONNES --- *@
                    <th>Téléphone</th>
                    <th>Ville</th>
                    @* ------------------------- *@
                    <th>Adresse</th>
                    <th>Client</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            @item.DateCommande.ToString("dd/MM/yyyy HH:mm")
                        </td>
                        <td>
                            @{
                                var badgeClass = item.Statut switch
                                {
                                    "En attente" => "bg-warning text-dark",
                                    "Acceptee" => "bg-info text-white",
                                    "Livree" => "bg-success text-white",
                                    "Annulee" => "bg-danger text-white",
                                    _ => "bg-secondary text-white"
                                };
                            }
                            <span class="badge @badgeClass rounded-pill">@item.Statut</span>
                        </td>
                        <td class="fw-bold text-primary">
                            @item.Total.ToString("N2") DT
                        </td>
                        @* --- AFFICHAGE DU TÉLÉPHONE ET DE LA VILLE --- *@
                        <td class="fw-bold">
                            <i class="bi bi-telephone me-1 text-muted"></i> @item.Telephone
                        </td>
                        <td>@item.Ville</td>
                        @* --------------------------------------------- *@
                        <td class="text-truncate" style="max-width: 150px;">
                            @item.AdresseLivraison
                        </td>
                        <td>
                            <small class="text-muted">@item.Utilisateur?.Email</small>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group shadow-sm">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>