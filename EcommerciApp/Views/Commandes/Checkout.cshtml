@model EcommerciApp.Models.Commande

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <h3 class="fw-bold mb-4 text-center">Finaliser la commande</h3>
                    <p class="text-muted text-center mb-4">Montant total à payer : <strong>@Model.Total.ToString("N2") DT</strong></p>

                    @* On pointe vers ConfirmerCommande *@
                    <form asp-action="ConfirmerCommande" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ville</label>
                            <input name="Ville" class="form-control rounded-3" placeholder="Ex: Tunis, Sousse..." required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Adresse de livraison</label>
                            <textarea name="AdresseLivraison" class="form-control rounded-3" rows="3"
                                      placeholder="Ex: 123 Rue de la Liberté" required></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Numéro de téléphone</label>
                            <input name="Telephone" type="tel" class="form-control rounded-3" placeholder="Ex: 22 123 456" required />
                        </div>

                        <div class="alert alert-info small border-0">
                            <i class="bi bi-cash-stack me-2"></i>Paiement en espèces à la livraison.
                        </div>

                        <button type="submit" class="btn btn-success w-100 py-3 fw-bold rounded-pill shadow-sm mt-3">
                            Confirmer et commander
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>